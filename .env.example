# Configurações do Backend (Use HTTPS para produção)
NODE_ENV=production
BACKEND_PORT=8080
BACKEND_SERVER_NAME=api.seudominio.com
BACKEND_URL=https://api.seudominio.com
PROXY_PORT=443

# Banco de Dados (Docker)
MYSQL_ENGINE=mariadb
MYSQL_VERSION=10.6
MYSQL_ROOT_PASSWORD=troque_essa_senha_forte
MYSQL_DATABASE=whaticket
MYSQL_PORT=3306
TZ=America/Fortaleza

# JWT
JWT_SECRET=troque_jwt_secret
JWT_REFRESH_SECRET=troque_jwt_refresh_secret

# Frontend
FRONTEND_PORT=80
FRONTEND_SSL_PORT=443
FRONTEND_SERVER_NAME=painel.seudominio.com
FRONTEND_URL=https://painel.seudominio.com

# Integrações
OPENAI_API_KEY=

# Configurações de Email (Opcional)
MAIL_HOST=
MAIL_PORT=
MAIL_USER=
MAIL_PASS=
MAIL_FROM=